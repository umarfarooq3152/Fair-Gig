# shared .env (copy to repo root as `.env` before `npm run dev`)
# JWT_SECRET is required — must match across auth-service, earnings-service, and grievance-service.
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>/<db_name>?sslmode=require&channel_binding=require
JWT_SECRET=change_this_to_a_long_random_string
AUTH_SERVICE_URL=http://localhost:8001
EARNINGS_SERVICE_URL=http://localhost:8002
ANOMALY_SERVICE_URL=http://localhost:8003
GRIEVANCE_SERVICE_URL=http://localhost:8004
ANALYTICS_SERVICE_URL=http://localhost:8005

# Supabase Storage (used by earnings-service for screenshot upload)
SUPABASE_URL=https://rboeauycggsgtdhuipah.supabase.co
SUPABASE_BUCKET=gig
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_not_publishable
